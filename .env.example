# SAP B1 SERVICE LAYER
SAP_SERVICE_LAYER_BASE_URL=
SAP_B1_COMPANY_DB=
SAP_B1_USERNAME=
SAP_B1_PASSWORD=

# GOOGLE API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional Map ID for Advanced Markers (defaults to DEMO_MAP_ID when unset)
# NEXT_PUBLIC_GOOGLE_MAP_ID=
GOOGLE_GENAI_API_KEY=

# AI-FM Open API — paste Company Api Secret (no quotes). Server sends it as "secret" on /authorize and "api_token" on /jobs.
AIFM_BASE_URL=
AIFM_API_TOKEN=

GOOGLE_API_KEY=
 # OR
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Syncfusion License Key
SYNCFUSION_LICENSE_KEY=

# JWT Secret Key
JWT_SECRET_KEY=

# Cron (scheduled tasks — use external scheduler on Vercel Hobby; see docs/PHASE2_CRON_SYNC.md)
CRON_SECRET=
# Production URL for scripts/run-hourly-job-sync-cron.mjs and GitHub Actions
JOB_SYNC_CRON_BASE_URL=http://localhost:4000/
JOB_SYNC_CRON_TZ=Asia/Manila
JOB_SYNC_CRON_START_HOUR=7
JOB_SYNC_CRON_END_HOUR=24

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Set to 1 in staging/production to log [egress] response byte sizes on server API routes
# (see logResponseSize in lib/supabase/listQueryHelpers.js).
#
# Monitoring workflow (PostgREST egress baseline):
# 1. Deploy egress changes, then set SUPABASE_EGRESS_LOG=1 in production.
# 2. In Supabase Dashboard → Usage → Egress, note PostgREST daily GB for 3 days before deploy.
# 3. After deploy, compare PostgREST daily GB for the next 3 days; target under ~500 MB/day.
# 4. Check server logs for [egress] lines on heavy routes (masterlist-summary, global-masterlist, etc.).
# SUPABASE_EGRESS_LOG=1
SUPABASE_EGRESS_LOG=
# Qwen (Alibaba DashScope) — OpenAI-compatible mode. Use .env.local; never commit real keys.
# QWEN_API_KEY and DASHSCOPE_API_KEY are both accepted (same value).
QWEN_API_KEY=
QWEN_MODEL=
# Optional: override compatible-mode base (default https://dashscope.aliyuncs.com/compatible-mode/v1)
# QWEN_API_BASE_URL=

# OPTIONAL: Redis URL for shared server caches (e.g. company memo header ticker on Supabase-heavy dashboards).
# When unset, the app skips Redis and reads the database directly.
# REDIS_URL=redis://default:PASSWORD@HOST:6379
# COMPANY_MEMO_TICKER_CACHE_TTL_SEC=120
